# Environment Variables
# Copy this file to .env.local and fill in the values

# PostgreSQL Database (from Supabase, Neon, or Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/portfolio?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"

# Email delivery
AZURE_COMMUNICATION_CONNECTION_STRING="endpoint=https://YOUR_RESOURCE.unitedstates.communication.azure.com/;accesskey=YOUR_KEY"
AZURE_EMAIL_SENDER="noreply@sherwoodtech.it.com"
CONTACT_NOTIFICATION_EMAIL="scott@sherwoodtech.it.com"

# Admin credentials (for initial seed)
ADMIN_EMAIL="scott@sherwoodtech.it.com"
ADMIN_PASSWORD="your-secure-password"
ADMIN_NAME="Scott Sherwood"
