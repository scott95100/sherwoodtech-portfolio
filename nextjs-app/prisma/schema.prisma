// Prisma Schema - PostgreSQL
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String    @unique
  password               String
  role                   Role      @default(USER)
  avatar                 String?
  bio                    String?
  website                String?
  linkedinUrl            String?
  githubUrl              String?
  twitterUrl             String?
  isActive               Boolean   @default(true)
  emailVerified          Boolean   @default(false)
  lastLogin              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  portfolio              Portfolio?
  contactMessages        ContactMessage[]
  clientProjects         ClientProject[]
  accounts               Account[]
  sessions               Session[]

  @@index([email])
  @@index([role])
}

enum Role {
  USER
  CLIENT
  ADMIN
}

// ─── NextAuth Tables ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Portfolio ────────────────────────────────────────────────────────────────

model Portfolio {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String   @default("Software Engineer")
  subtitle    String?
  description String
  location    String?
  phone       String?
  resumeUrl   String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       Skill[]
  experiences  Experience[]
  education    Education[]
  projects     Project[]
  certifications Certification[]
}

// ─── Skills ───────────────────────────────────────────────────────────────────

model Skill {
  id          String        @id @default(cuid())
  portfolioId String
  name        String
  level       SkillLevel
  category    SkillCategory
  createdAt   DateTime      @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SkillCategory {
  FRONTEND
  BACKEND
  DATABASE
  DEVOPS
  MOBILE
  OTHER
}

// ─── Experience ───────────────────────────────────────────────────────────────

model Experience {
  id           String    @id @default(cuid())
  portfolioId  String
  company      String
  position     String
  startDate    DateTime
  endDate      DateTime?
  current      Boolean   @default(false)
  description  String?
  technologies String[]
  achievements String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// ─── Education ────────────────────────────────────────────────────────────────

model Education {
  id          String    @id @default(cuid())
  portfolioId String
  institution String
  degree      String
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  gpa         String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(cuid())
  portfolioId String
  title       String
  description String
  technologies String[]
  githubUrl   String?
  liveUrl     String?
  imageUrl    String?
  featured    Boolean   @default(false)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// ─── Certifications ───────────────────────────────────────────────────────────

model Certification {
  id          String    @id @default(cuid())
  portfolioId String
  name        String
  issuer      String
  issueDate   DateTime?
  expiryDate  DateTime?
  credentialId String?
  credentialUrl String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id        String        @id @default(cuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

// ─── Client Projects ──────────────────────────────────────────────────────────

model ClientProject {
  id          String              @id @default(cuid())
  clientId    String
  title       String
  description String
  status      ClientProjectStatus @default(DISCOVERY)
  startDate   DateTime?
  deadline    DateTime?
  liveUrl     String?
  repoUrl     String?
  technologies String[]
  budget      String?
  isVisible   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  client      User                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  notes       ClientNote[]

  @@index([clientId])
}

enum ClientProjectStatus {
  DISCOVERY
  PROPOSAL
  IN_PROGRESS
  REVIEW
  COMPLETE
  ON_HOLD
}

model ClientNote {
  id              String   @id @default(cuid())
  clientProjectId String
  authorId        String?
  content         String
  isInternal      Boolean  @default(false)
  createdAt       DateTime @default(now())

  project ClientProject @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)

  @@index([clientProjectId])
}

// ─── Invitations ──────────────────────────────────────────────────────────────

model Invitation {
  id        String    @id @default(cuid())
  email     String    @unique
  token     String    @unique @default(cuid())
  role      Role      @default(CLIENT)
  used      Boolean   @default(false)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  invitedBy String?
}

// ─── Project Inquiries (Pricing Calculator Leads) ─────────────────────────────

model ProjectInquiry {
  id              String              @id @default(cuid())
  // Contact info
  name            String
  email           String
  company         String?
  phone           String?
  // Industry & location
  industry        String?             // user's industry
  country         String?             // user's country
  // Project type
  projectType     String              // 'pilot' | 'full'
  serviceCategory String              // e.g. 'salesforce', 'web', 'api', 'consulting'
  // Scope inputs
  title           String
  description     String
  features        String[]            // selected feature checkboxes
  complexity      String              // 'simple' | 'moderate' | 'complex'
  hasDesign       Boolean             @default(false)
  needsHosting    Boolean             @default(false)
  needsAuth       Boolean             @default(false)
  needsIntegrations Boolean           @default(false)
  integrationNotes String?
  // Timeline
  desiredTimeline String              // 'asap' | '1month' | '3months' | 'flexible'
  // Calculated outputs
  estimatedLow    Int                 // in USD
  estimatedHigh   Int
  estimatedWeeks  Int
  // Admin fields
  status          InquiryStatus       @default(NEW)
  adminNotes      String?
  convertedToProject Boolean          @default(false)
  // UTM attribution
  utmSource       String?             // e.g. 'linkedin', 'twitter', 'email'
  utmCampaign     String?             // campaign slug
  utmMedium       String?             // e.g. 'social', 'cpc'
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([email])
}

enum InquiryStatus {
  NEW
  REVIEWED
  PROPOSAL_SENT
  CONVERTED
  DECLINED
}

// ─── Campaign Manager ─────────────────────────────────────────────────────────

model Campaign {
  id          String           @id @default(cuid())
  name        String
  goal        String?          // e.g. "Generate 5 leads for Salesforce pilot"
  platforms   String[]         // e.g. ["linkedin", "twitter"]
  status      CampaignStatus   @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  utmSlug     String           @unique  // used as utm_campaign value
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  posts       CampaignPost[]

  @@index([status])
}

model CampaignPost {
  id           String       @id @default(cuid())
  campaignId   String
  platform     String       // 'linkedin' | 'twitter' | 'email' | 'other'
  content      String       // the post body text
  status       PostStatus   @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum PostStatus {
  DRAFT
  READY
  PUBLISHED
}

// ─── Omnis DevOps Waitlist ───────────────────────────────────────────────────

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  source    String?  @default("platform-page")
  createdAt DateTime @default(now())
}
